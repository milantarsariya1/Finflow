datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  passwordHash   String
  monthlyIncome  Float          @default(0)
  bankBalance    Float          @default(0)
  savings        Float          @default(0)
  createdAt      DateTime       @default(now())
  
  securityQuestion String         @default("What was the name of your first pet?")
  securityAnswer   String         @default("buddy")
  
  fixedExpenses  FixedExpense[]
  transactions   Transaction[]
  goals          Goal[]
}

model FixedExpense {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "income" | "expense"
  amount    Float
  category  String   // e.g., "Food", "Bills", "Shopping", "Salary", etc.
  note      String?
  date      DateTime @default(now())
}

model Goal {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  targetAmount Float
  years        Float
  requiredSip  Float
  createdAt    DateTime @default(now())
}
